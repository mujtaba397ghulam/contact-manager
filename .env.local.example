# MongoDB Connection Options
# ==========================

# OPTION 1: MongoDB Atlas (Cloud - Recommended)
# No installation required, works from any PC
# MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/contact-manager?retryWrites=true&w=majority

# OPTION 2: Local MongoDB 
# Requires MongoDB installed and running on your PC
MONGODB_URI=mongodb://localhost:27017/contact-manager

# Database name
MONGODB_DB=contact-manager

# IMPORTANT: 
# - For Atlas, make sure to whitelist your IP address in Atlas Network Access
# - For local, make sure MongoDB service is running